{
  "name": "devbox-daemon",
  "version": "0.1.0",
  "description": "Control AI coding tools from your phone. DevBox daemon bridges your mobile app to Claude Code, Aider, and more.",
  "type": "module",
  "bin": {
    "devbox-daemon": "./bin/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["devbox", "claude", "ai", "remote", "mobile", "daemon", "cli"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lostboi/devbox"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "bonjour-service": "^1.2.1",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
